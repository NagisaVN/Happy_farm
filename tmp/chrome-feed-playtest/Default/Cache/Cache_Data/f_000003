.shop-flash-badge,.shop-discount-badge{display:inline-block;font-size:.65rem;padding:2px 6px;border-radius:7px;margin-left:5px}.shop-flash-badge{background:#ff7a18;color:#fff}.shop-discount-badge{background:#e83e67;color:#fff}.shop-countdown{display:block;color:#c64d00;font-weight:700;margin-top:4px}.card-price del{opacity:.55;margin-right:4px}
