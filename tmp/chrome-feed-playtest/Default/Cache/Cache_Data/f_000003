/* Switch UI */
.switch {
    position: relative;
    display: inline-block;
    width: 48px;
    height: 24px;
}

.switch input { 
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #7f8c8d;
    transition: .3s;
}

.slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: .3s;
}

input:checked + .slider {
    background-color: #2ecc71;
}

input:checked + .slider:before {
    transform: translateX(24px);
}

.slider.round {
    border-radius: 24px;
}

.slider.round:before {
    border-radius: 50%;
}

.btn-danger {
    background: linear-gradient(to bottom, #e74c3c, #c0392b);
    border: none;
    border-radius: 8px;
    padding: 10px 0;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    font-family: var(--font-primary);
    transition: transform 0.1s, filter 0.1s;
}

.btn-danger:hover {
    filter: brightness(1.1);
}

.btn-danger:active {
    transform: scale(0.97);
}

.btn-logout-account {
    width: 100%;
    padding: 10px 0;
    border: 1.5px solid rgba(241, 196, 15, 0.55);
    border-radius: 8px;
    background: rgba(241, 196, 15, 0.12);
    color: #ffe49a;
    font-family: var(--font-primary);
    font-size: 0.9rem;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.1s, background 0.15s;
}

.btn-logout-account:hover {
    background: rgba(241, 196, 15, 0.22);
}

.btn-logout-account:active {
    transform: scale(0.97);
}

/* --- Floating Toast Notification --- */
.toast {
    position: absolute;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    background: rgba(30, 20, 10, 0.9);
    border: 2px solid var(--color-gold);
    border-radius: 20px;
    padding: 8px 24px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    z-index: 1000;
    pointer-events: none;
    transition: opacity 0.3s, transform 0.3s;
    opacity: 1;
}

.toast.hide {
    opacity: 0;
    transform: translateX(-50%) translateY(30px);
}

#toast-message {
    color: #fff;
    font-weight: 600;
    font-size: 0.85rem;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
}

/* --- Particle Effect --- */
.particle {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    z-index: 90;
    animation: particle-fly 0.6s forwards cubic-bezier(0.1, 0.8, 0.3, 1);
}

/* --- Animations Definitions --- */
@keyframes walking-bob {
    0% {
        transform: translate(-50%, -91%) translateY(0) rotate(-5deg) scaleX(1.02) scaleY(0.98);
    }
    25% {
        transform: translate(-50%, -91%) translateY(-6px) rotate(-1deg) scaleX(0.97) scaleY(1.03);
    }
    50% {
        transform: translate(-50%, -91%) translateY(0) rotate(5deg) scaleX(1.02) scaleY(0.98);
    }
    75% {
        transform: translate(-50%, -91%) translateY(-6px) rotate(1deg) scaleX(0.97) scaleY(1.03);
    }
    100% {
        transform: translate(-50%, -91%) translateY(0) rotate(-5deg) scaleX(1.02) scaleY(0.98);
    }
}

@keyframes shaking {
    0% { transform: translate(-2px, -2px) rotate(-1deg); }
    100% { transform: translate(2px, 2px) rotate(1deg); }
}

@keyframes digging-bounce {
    0% {
        transform: translate(-50%, -91%) scale(1.0, 1.0) rotate(0deg);
    }
    50% {
        transform: translate(-50%, -91%) scale(1.1, 0.85) rotate(-6deg);
    }
    100% {
        transform: translate(-50%, -91%) scale(0.95, 1.05) rotate(10deg);
    }
}

@keyframes harvesting-bounce {
    0% {
        transform: translate(-50%, -91%) translateY(0) rotate(0deg);
    }
    50% {
        transform: translate(-50%, -91%) translateY(-10px) rotate(-8deg) scale(0.95, 1.05);
    }
    100% {
        transform: translate(-50%, -91%) translateY(0) rotate(8deg) scale(1.05, 0.95);
    }
}

@keyframes floating-basket {
    0% { transform: translateX(-50%) translateY(0); }
    100% { transform: translateX(-50%) translateY(-8px); }
}

@keyframes crop-bounce {
    0%, 100% { transform: translateY(10px) scale(1); }
    50% { transform: translateY(7px) scale(1.03); }
}

@keyframes rotating-star {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

@keyframes particle-fly {
    0% {
        opacity: 1;
        transform: translate(0, 0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(var(--tx), var(--ty)) scale(0.2);
    }
}

