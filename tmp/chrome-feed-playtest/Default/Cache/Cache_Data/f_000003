/* ==========================================================================
   ANTI-GRAVITY MODE STYLES & ANIMATIONS
   ========================================================================== */

/* Active Toggle button */
#btn-antigravity.active {
    background: radial-gradient(circle, #9b59b6, #8e44ad);
    border-color: #f1c40f;
    box-shadow: 0 0 15px rgba(155, 89, 182, 0.8), inset 0 0 5px rgba(255, 255, 255, 0.5);
    animation: space-pulse 1.5s infinite alternate ease-in-out;
}

@keyframes space-pulse {
    0% { transform: scale(1); filter: brightness(1); }
    100% { transform: scale(1.15); filter: brightness(1.2) drop-shadow(0 0 8px #9b59b6); }
}

/* Viewport Vignette/Cosmic Aura Effect */
#game-viewport.antigravity-active::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    box-shadow: inset 0 0 100px rgba(128, 0, 128, 0.45), inset 0 0 50px rgba(0, 0, 255, 0.3);
    z-index: 1000;
    mix-blend-mode: screen;
    animation: cosmic-pulse 3s infinite alternate ease-in-out;
}

@keyframes cosmic-pulse {
    0% {
        opacity: 0.65;
        box-shadow: inset 0 0 80px rgba(128, 0, 128, 0.35), inset 0 0 40px rgba(0, 0, 255, 0.2);
    }
    100% {
        opacity: 1.0;
        box-shadow: inset 0 0 150px rgba(155, 89, 182, 0.7), inset 0 0 80px rgba(52, 152, 219, 0.55);
    }
}

/* Screen Shake Animation */
@keyframes screen-shake {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    10% { transform: translate(-4px, 3px) rotate(-0.5deg); }
    30% { transform: translate(3px, -2px) rotate(0.5deg); }
    50% { transform: translate(-3px, -3px) rotate(-0.5deg); }
    70% { transform: translate(2px, 2px) rotate(0.5deg); }
    90% { transform: translate(-1px, -1px) rotate(0deg); }
}

.antigravity-shake {
    animation: screen-shake 0.5s ease-out !important;
}

/* Floating Animations for Entities */
@keyframes antigravity-float {
    0% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-16px) rotate(1.5deg); }
    100% { transform: translateY(0) rotate(0deg); }
}

@keyframes antigravity-shadow {
    0% { transform: translateX(-50%) scale(1); opacity: 0.35; }
    50% { transform: translateX(-50%) scale(0.75); opacity: 0.15; }
    100% { transform: translateX(-50%) scale(1); opacity: 0.35; }
}

/* Farmer Float overrides */
.antigravity-active .farmer-character #farmer-canvas {
    animation: antigravity-float 3.5s infinite ease-in-out;
}
.antigravity-active .farmer-character .farmer-shadow {
    animation: antigravity-shadow 3.5s infinite ease-in-out;
}

/* Shiba Dog Float overrides */
.antigravity-active .pet-dog-character .dog-emoji {
    animation: antigravity-float 4.2s infinite ease-in-out;
    animation-delay: 0.5s;
}
.antigravity-active .pet-dog-character .dog-shadow {
    animation: antigravity-shadow 4.2s infinite ease-in-out;
    animation-delay: 0.5s;
}

/* Chickens Float overrides */
.antigravity-active .chicken-character .chicken-emoji {
    animation: antigravity-float 3.8s infinite ease-in-out;
}
.antigravity-active .chicken-character .chicken-shadow {
    animation: antigravity-shadow 3.8s infinite ease-in-out;
}
.antigravity-active .chicken-character:nth-child(2n) .chicken-emoji {
    animation-delay: 0.8s;
    animation-duration: 4.1s;
}
.antigravity-active .chicken-character:nth-child(2n) .chicken-shadow {
    animation-delay: 0.8s;
    animation-duration: 4.1s;
}
.antigravity-active .chicken-character:nth-child(3n) .chicken-emoji {
    animation-delay: 1.5s;
    animation-duration: 3.5s;
}
.antigravity-active .chicken-character:nth-child(3n) .chicken-shadow {
    animation-delay: 1.5s;
    animation-duration: 3.5s;
}

/* Cows Float overrides */
.antigravity-active .cow-character .cow-emoji {
    animation: antigravity-float 4.5s infinite ease-in-out;
    animation-delay: 0.2s;
}
.antigravity-active .cow-character .cow-shadow {
    animation: antigravity-shadow 4.5s infinite ease-in-out;
    animation-delay: 0.2s;
}
.antigravity-active .cow-character:nth-child(2n) .cow-emoji {
    animation-delay: 1.1s;
    animation-duration: 4.8s;
}
.antigravity-active .cow-character:nth-child(2n) .cow-shadow {
    animation-delay: 1.1s;
    animation-duration: 4.8s;
}

/* Crops Float overrides */
.antigravity-active .plot-upright .crop-sprite {
    animation: antigravity-float 4s infinite ease-in-out;
}
.antigravity-active .plot:nth-child(3n) .plot-upright .crop-sprite {
    animation-delay: 0.3s;
    animation-duration: 3.7s;
}
.antigravity-active .plot:nth-child(3n+1) .plot-upright .crop-sprite {
    animation-delay: 0.9s;
    animation-duration: 4.3s;
}
.antigravity-active .plot:nth-child(3n+2) .plot-upright .crop-sprite {
    animation-delay: 1.6s;
    animation-duration: 3.9s;
}

/* Buildings Float overrides */
.antigravity-active .farm-building > img,
.antigravity-active .farm-building > svg,
.antigravity-active #signpost-building svg {
    animation: antigravity-float 5s infinite ease-in-out;
}
.antigravity-active #farmhouse-overlay img {
    animation: antigravity-float 5.2s infinite ease-in-out;
    animation-delay: 0.1s;
}
.antigravity-active #barn-overlay img {
    animation: antigravity-float 5.5s infinite ease-in-out;
    animation-delay: 0.7s;
}
.antigravity-active #shop-building img {
    animation: antigravity-float 4.8s infinite ease-in-out;
    animation-delay: 0.3s;
}
.antigravity-active #pet-building img {
    animation: antigravity-float 5.1s infinite ease-in-out;
    animation-delay: 0.9s;
}
.antigravity-active #chicken-coop svg {
    animation: antigravity-float 4.7s infinite ease-in-out;
    animation-delay: 0.5s;
}
.antigravity-active #cow-pen svg {
    animation: antigravity-float 5.3s infinite ease-in-out;
    animation-delay: 0.2s;
}

/* Interactive Push Bounce Effect */
@keyframes antigravity-push-bounce {
    0% { transform: translateY(0) rotate(0deg) scale(1); }
    30% { transform: translateY(-70px) rotate(25deg) scale(1.15); }
    70% { transform: translateY(-20px) rotate(-8deg) scale(0.95); }
    100% { transform: translateY(0) rotate(0deg) scale(1); }
}

.antigravity-pushed {
    animation: antigravity-push-bounce 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
}

/* Floating Loot Particles */
@keyframes particle-float-up {
    0% {
        transform: translate(0, 0) scale(1);
        opacity: 1;
    }
    100% {
        transform: translate(var(--tx), var(--ty)) scale(0.6);
        opacity: 0;
    }
}

/* Paved Paths Ground Container & Tiles */
#paved-paths-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 1280px;
    height: 720px;
    pointer-events: none;
    z-index: 1;
}

.paved-path-tile {
    position: absolute;
    width: 40px;
    height: 40px;
    background-color: #d1976a; /* Warm clay dirt brown */
    border-radius: 8px 12px 6px 10px; /* Irregular border radius for natural dirt look */
    box-shadow: inset 0 0 8px rgba(100, 50, 20, 0.45);
    z-index: 1;
    transition: background-color 0.2s;
}

/* Jagged grass patches along the sides of the dirt road */
.paved-path-tile::before {
    content: '';
    position: absolute;
    top: -4px;
    left: -4px;
    right: -4px;
    bottom: -4px;
    pointer-events: none;
    /* Soft green grass circles overlapping the edges */
    background-image: 
        radial-gradient(circle at 10% 12%, #7cb342 6px, transparent 6px),
        radial-gradient(circle at 88% 15%, #7cb342 5px, transparent 5px),
        radial-gradient(circle at 12% 86%, #558b2f 5px, transparent 5px),
        radial-gradient(circle at 86% 88%, #7cb342 6px, transparent 6px),
        radial-gradient(circle at 50% -2px, #558b2f 4px, transparent 4px),
        radial-gradient(circle at 48% 42px, #7cb342 5px, transparent 5px),
        radial-gradient(circle at -2px 48%, #7cb342 4px, transparent 4px),
        radial-gradient(circle at 42px 52%, #558b2f 4px, transparent 4px);
}

/* Active Pave Mode HUD Button */
#btn-pave-mode.active {
    background: radial-gradient(circle, #e67e22, #d35400) !important;
    border-color: #f1c40f !important;
    box-shadow: 0 0 15px rgba(230, 126, 34, 0.8), inset 0 0 5px rgba(255, 255, 255, 0.5) !important;
    animation: space-pulse 1.5s infinite alternate ease-in-out;
}

/* Start marker for auto-paving */
.pave-start-marker {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 3px solid #f1c40f;
    box-sizing: border-box;
    border-radius: 8px;
    z-index: 10;
    pointer-events: none;
    box-shadow: 0 0 10px #f1c40f, inset 0 0 6px #f1c40f;
    animation: pave-marker-pulse 1.2s infinite ease-in-out;
}

@keyframes pave-marker-pulse {
    0% {
        transform: scale(0.95);
        opacity: 0.7;
    }
    50% {
        transform: scale(1.05);
        opacity: 1;
        box-shadow: 0 0 15px #f39c12, inset 0 0 10px #f39c12;
    }
    100% {
        transform: scale(0.95);
        opacity: 0.7;
    }
}

/* Disable pointer events for buildings, plots, characters, and other overlays in Pave Mode */
#farm-stage.pave-mode-active .clickable-building,
#farm-stage.pave-mode-active .plot,
#farm-stage.pave-mode-active .farmer-character,
#farm-stage.pave-mode-active .pet-dog-character,
#farm-stage.pave-mode-active .chicken-character,
#farm-stage.pave-mode-active .cow-character,
#farm-stage.pave-mode-active .decor-outside {
    pointer-events: none !important;
}
