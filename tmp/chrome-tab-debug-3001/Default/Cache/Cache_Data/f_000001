                        <div class="hud-item" id="hud-coins" title="Tiền vàng">
                            <span class="hud-icon coin-icon">🪙</span>
                            <span id="coin-value" class="hud-value">12,450</span>
                        </div>
                        <div class="hud-item" id="hud-gems" title="Kim cương">
                            <span class="hud-icon gem-icon">💎</span>
                            <span id="gem-value" class="hud-value">35</span>
                        </div>
                        <div class="hud-item" id="hud-energy" title="Năng lượng">
                            <span class="hud-icon energy-icon">⚡</span>
                            <div class="energy-bar-wrapper">
                                <div id="energy-bar-fill" class="energy-bar-fill" style="width: 100%"></div>
                                <span id="energy-value" class="bar-value">120/120</span>
                            </div>
                            <button id="btn-add-energy" class="btn-plus">+</button>
                        </div>
                    </div>

                    <!-- Right: Level and Menu -->
                    <div class="hud-group right">
                        <div class="hud-item" id="hud-level" title="Cấp độ">
                            <div class="level-star">
                                <span class="star-icon">⭐</span>
                                <span id="level-value">15</span>
                            </div>
                            <div class="xp-bar-wrapper">
                                <div id="xp-bar-fill" class="xp-bar-fill" style="width: 62.5%"></div>
                                <span id="xp-value" class="bar-value">1,250/2,000</span>
                            </div>
                        </div>

                        <!-- Mini utility buttons -->
                        <div class="utility-buttons">
                            <button id="btn-mail" class="btn-utility" title="Thư">✉️</button>
                            <button id="btn-rank" class="btn-utility" title="Bảng xếp hạng">🏆</button>
                            <button id="btn-antigravity" class="btn-utility" title="Kháng trọng lực">🛸</button>
                            <button id="btn-settings" class="btn-utility" title="Cài đặt">⚙️</button>
                        </div>
                    </div>
                </div>

                <!-- HUD - Left Sidebar Menu -->
                <div id="hud-left-menu">
                    <button class="menu-btn active" id="btn-shop-menu" data-target="shop">
                        <span class="menu-btn-icon">🏪</span>
                        <span class="menu-btn-text">Cửa Hàng</span>
                    </button>
                    <button class="menu-btn" id="btn-inventory-menu" data-target="inventory">
                        <span class="menu-btn-icon">🎒</span>
                        <span class="menu-btn-text">Kho Đồ</span>
                    </button>
                    <button class="menu-btn" id="btn-quests-menu" data-target="quests">
                        <span class="menu-btn-icon">📋</span>
                        <span class="menu-btn-text">Nhiệm Vụ</span>
                        <span id="quest-badge" class="badge hide">0</span>
                    </button>
                    <button class="menu-btn" id="btn-achieve-menu" data-target="achievements">
                        <span class="menu-btn-icon">🏆</span>
                        <span class="menu-btn-text">Thành Tích</span>
                    </button>
                    <button class="menu-btn" id="btn-stats-menu" data-target="stats">
                        <span class="menu-btn-icon">📊</span>
                        <span class="menu-btn-text">Thống Kê</span>
                    </button>
                    <button class="menu-btn" id="btn-pets-menu" data-target="pets">
                        <span class="menu-btn-icon">🐾</span>
                        <span class="menu-btn-text">Thú Cưng</span>
                    </button>
                </div>

                <!-- HUD - Bottom Controls -->
                <div id="hud-bottom-right">
                    <button class="circle-btn" id="btn-harvest-all" title="Thu hoạch tất cả cây chín" style="position: relative;">
                        <span class="circle-btn-icon">🌾</span>
                        <span class="circle-btn-text">Gặt Hết</span>
                        <span id="harvest-all-badge" class="badge hide">0</span>
                    </button>
                    <button class="circle-btn" id="btn-design" title="Chỉnh sửa nông trại">
                        <span class="circle-btn-icon">🛠️</span>
                        <span class="circle-btn-text">Thiết Kế</span>
                    </button>
                    <button class="circle-btn" id="btn-pave-mode" title="Chế độ lót đường đất">
                        <span class="circle-btn-icon">🟫</span>
                        <span class="circle-btn-text">Đường Đất</span>
                    </button>
                    <button class="circle-btn" id="btn-map" title="Bản đồ">
                        <span class="circle-btn-icon">🗺️</span>
                        <span class="circle-btn-text">Bản Đồ</span>
                    </button>
                    <button class="circle-btn" id="btn-market" title="Chợ nông sản">
                        <span class="circle-btn-icon">🏪</span>
                        <span class="circle-btn-text">Chợ</span>
                    </button>
                </div>

                <!-- Selected Crop Detail Bar (Bottom Center) -->
                <div id="crop-detail-panel" class="detail-panel hide">
                    <button id="btn-close-crop-detail" class="crop-detail-close" type="button" aria-label="Đóng bảng phân bón">×</button>
                    <div class="detail-content">
                        <img id="detail-crop-icon" src="" alt="crop icon">
                        <div class="detail-text">
                            <h3 id="detail-crop-name">Carrot</h3>
                            <span id="detail-crop-timer">⏳ 00:05:30</span>
                        </div>
                        <div class="fertilizer-controls" id="fertilizer-controls">
                            <button class="fertilizer-btn" id="btn-fertilizer-mid" title="Phân bón Trung cấp (Nhanh 50%)">
                                <span>🧪 Bón Trung (50%)</span>
                                <span id="mid-fertilizer-count">x0</span>
                            </button>
                            <button class="fertilizer-btn" id="btn-fertilizer-high" title="Phân bón Cao cấp (Chín ngay)">
                                <span>💎 Bón Cao (100%)</span>
                                <span id="high-fertilizer-count">x0</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- POPUP: Seed Selector (Carrot, Corn, Tomato, Pumpkin) -->
            <div id="seed-popup" class="popover hide">
                <div class="popover-arrow"></div>
                <button id="btn-close-seed-popup" class="popover-close">×</button>
                <div class="popover-header">Chọn hạt giống</div>
                <div class="seed-list">
                    <!-- Seed items will be dynamic but follow format below -->
                    <div class="seed-row">
                        <button class="seed-item" data-seed="carrot">
                            <div class="seed-icon-wrapper">🥕</div>
                            <div class="seed-info">
                                <span class="seed-name">Cà rốt</span>
                                <span class="seed-count" id="count-carrot">x10</span>
                            </div>
                        </button>
                        <button class="btn-plant-all" data-seed="carrot" title="Trồng vào tất cả ô đất trống">Tất
                            cả</button>
                    </div>
                    <div class="seed-row">
                        <button class="seed-item" data-seed="corn">
                            <div class="seed-icon-wrapper">🌽</div>
                            <div class="seed-info">
                                <span class="seed-name">Ngô</span>
                                <span class="seed-count" id="count-corn">x8</span>
                            </div>
                        </button>
                        <button class="btn-plant-all" data-seed="corn" title="Trồng vào tất cả ô đất trống">Tất
                            cả</button>
                    </div>
                    <div class="seed-row">
                        <button class="seed-item" data-seed="tomato">
                            <div class="seed-icon-wrapper">🍅</div>
                            <div class="seed-info">
                                <span class="seed-name">Cà chua</span>
                                <span class="seed-count" id="count-tomato">x5</span>
                            </div>
                        </button>
                        <button class="btn-plant-all" data-seed="tomato" title="Trồng vào tất cả ô đất trống">Tất
                            cả</button>
                    </div>
                    <div class="seed-row">
                        <button class="seed-item" data-seed="pumpkin">
                            <div class="seed-icon-wrapper">🎃</div>
                            <div class="seed-info">
                                <span class="seed-name">Bí ngô</span>
                                <span class="seed-count" id="count-pumpkin">x3</span>
                            </div>
                        </button>
                        <button class="btn-plant-all" data-seed="pumpkin" title="Trồng vào tất cả ô đất trống">Tất
                            cả</button>
                    </div>
                </div>
            </div>

            <!-- MODAL: Cửa Hàng (Shop) -->
            <div id="modal-shop" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>🏪 CỬA HÀNG HẠT GIỐNG</h2>
                        <button class="modal-close" data-close="shop">×</button>
                    </div>
                    <div class="modal-body">
                        <div class="shop-tabs">
                            <button class="shop-tab active" data-tab="buy">Mua Hạt Giống</button>
                            <button class="shop-tab" data-tab="sell">Bán Nông Sản</button>
                        </div>
                        <div id="shop-buy-list" class="shop-grid">
                            <!-- JS will populate shop cards here -->
                        </div>
                        <div id="shop-sell-list" class="shop-grid hide">
                            <!-- JS will populate sell cards here -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL: Kho Đồ (Inventory) -->
            <div id="modal-inventory" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>🎒 KHO ĐỒ NÔNG TRẠI</h2>
                        <button class="modal-close" data-close="inventory">×</button>
                    </div>
                    <div class="modal-body">
                        <div class="inventory-section">
                            <h3>Hạt Giống Đang Có</h3>
                            <div id="inv-seeds-grid" class="inventory-grid"></div>
                        </div>
                        <hr class="modal-divider">
                        <div class="inventory-section">
                            <h3>Nông Sản Đã Thu Hoạch</h3>
                            <div id="inv-crops-grid" class="inventory-grid"></div>
                        </div>
                        <hr class="modal-divider">
                        <div class="inventory-section">
                            <h3>Phân Bón Nông Nghiệp</h3>
                            <div id="inv-fertilizers-grid" class="inventory-grid"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL: Nhiệm Vụ (Quests) -->
            <div id="modal-quests" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>📋 NHIỆM VỤ NÔNG TRẠI</h2>
                        <button class="modal-close" data-close="quests">×</button>
                    </div>
                    <div class="modal-body">
                        <div class="weekly-board-strip">
                            <div>
                                <span class="weekly-label">Điểm tuần</span>
                                <strong id="weekly-score">0 điểm</strong>
                            </div>
                            <div>
                                <span class="weekly-label">Còn lại</span>
                                <strong id="weekly-reset">--</strong>
                            </div>
                        </div>
                        <div id="weekly-milestones" class="weekly-milestones"></div>
                        <div id="quest-list" class="order-container">
                            <!-- Delivery orders populated by JS -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL: Thành Tích (Achievements) -->
            <!-- MODAL: Weekly Leaderboard -->
            <div id="modal-leaderboard" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism leaderboard-modal">
                    <div class="modal-header">
                        <h2>BẢNG XẾP HẠNG TUẦN</h2>
                        <button class="modal-close" data-close="leaderboard">Ã—</button>
                    </div>
                    <div class="modal-body">
                        <div class="leaderboard-summary">
                            <div>
                                <span class="weekly-label">Hạng của bạn</span>
                                <strong id="leaderboard-my-rank">Chưa có điểm</strong>
                            </div>
                            <div>
                                <span class="weekly-label">Còn lại</span>
                                <strong id="leaderboard-reset">--</strong>
                            </div>
                        </div>
                        <div id="rank-reward-panel" class="rank-reward-panel"></div>
                        <div id="leaderboard-list" class="leaderboard-list"></div>
                    </div>
                </div>
            </div>

            <div id="modal-achievements" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>🏆 THÀNH TÍCH ĐẠT ĐƯỢC</h2>
                        <button class="modal-close" data-close="achievements">×</button>
                    </div>
                    <div class="modal-body">
                        <div id="achievement-list" class="achievement-container">
                            <!-- Achievements populated by JS -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL: Thống Kê (Stats) -->
            <div id="modal-stats" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>📊 THỐNG KÊ NÔNG TRẠI</h2>
                        <button class="modal-close" data-close="stats">×</button>
                    </div>
                    <div class="modal-body">
                        <div class="stats-grid">
                            <div class="stats-card">
                                <span class="stats-label">Tổng số cây đã trồng:</span>
                                <span id="stats-planted" class="stats-value">0</span>
                            </div>
                            <div class="stats-card">
                                <span class="stats-label">Tổng số nông sản thu hoạch:</span>
                                <span id="stats-harvested" class="stats-value">0</span>
                            </div>
                            <div class="stats-card">
                                <span class="stats-label">Tổng số tiền đã kiếm:</span>
                                <span id="stats-coins-earned" class="stats-value">0</span>
                            </div>
                            <div class="stats-card">
                                <span class="stats-label">Tổng số tiền đã tiêu:</span>
                                <span id="stats-coins-spent" class="stats-value">0</span>
                            </div>
                            <div class="stats-card font-highlight">
                                <span class="stats-label">Thời gian làm nông:</span>
                                <span id="stats-time-played" class="stats-value">0 phút</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL: Thú Cưng (Pets) -->
            <div id="modal-pets" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>🐾 THÚ CƯNG CỦA BẠN</h2>
                        <button class="modal-close" data-close="pets">×</button>
                    </div>
                    <div class="modal-body">
                        <div class="pets-container">
                            <div class="pet-card active">
                                <div class="pet-avatar">🐕</div>
                                <div class="pet-details">
                                    <h3>Cún Shiba</h3>
                                    <p>Trông coi nông trại và nhặt tiền vàng rơi rớt.</p>
                                    <span class="pet-status">Đang hoạt động</span>
                                </div>
                            </div>
                            <div class="pet-card locked">
                                <div class="pet-avatar">🐈</div>
                                <div class="pet-details">
                                    <h3>Mèo Tam Thể</h3>
                                    <p>Tăng 10% năng lượng hồi phục mỗi phút.</p>
                                    <button class="btn-unlock-pet">Mở khóa: 50 💎</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL: Cài Đặt (Settings) -->
            <div id="modal-settings" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism">
                    <div class="modal-header">
                        <h2>⚙️ CÀI ĐẶT GAME</h2>
                        <button class="modal-close" data-close="settings">×</button>
                    </div>
                    <div class="modal-body">
                        <div class="settings-options">
                            <div class="setting-row">
                                <span>Âm thanh hiệu ứng (SFX)</span>
                                <label class="switch">
                                    <input type="checkbox" id="toggle-sfx" checked>
                                    <span class="slider round"></span>
                                </label>
                            </div>
                            <div class="setting-row">
                                <span>Nhạc nền (BGM)</span>
                                <label class="switch">
                                    <input type="checkbox" id="toggle-bgm">
                                    <span class="slider round"></span>
                                </label>
                            </div>
                            <hr class="modal-divider">
                            <button id="btn-reset-game" class="btn-danger">Reset Dữ Liệu Game</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Prompt Dialog -->
            <div id="modal-custom-prompt" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism dialog-modal">
                    <div class="modal-header">
                        <h2 id="custom-prompt-title">🏷️ ĐỔI TÊN NÔNG TRẠI</h2>
                        <button class="modal-close" id="btn-custom-prompt-close">×</button>
                    </div>
                    <div class="modal-body dialog-body">
                        <p id="custom-prompt-message" class="dialog-message">Nhập tên nông trại mới của bạn (tối đa 15 ký tự):</p>
                        <input type="text" id="custom-prompt-input" class="dialog-input" maxlength="15">
                        <div class="dialog-buttons">
                            <button id="btn-custom-prompt-ok" class="rect-btn success dialog-btn">Xác Nhận</button>
                            <button id="btn-custom-prompt-cancel" class="rect-btn danger dialog-btn">Hủy</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Confirm Dialog -->
            <div id="modal-custom-confirm" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism dialog-modal">
                    <div class="modal-header">
                        <h2 id="custom-confirm-title">❔ XÁC NHẬN</h2>
                        <button class="modal-close" id="btn-custom-confirm-close">×</button>
                    </div>
                    <div class="modal-body dialog-body">
                        <p id="custom-confirm-message" class="dialog-message">Bạn có chắc chắn muốn thực hiện hành động này không?</p>
                        <div class="dialog-buttons">
                            <button id="btn-custom-confirm-ok" class="rect-btn success dialog-btn">Đồng Ý</button>
                            <button id="btn-custom-confirm-cancel" class="rect-btn danger dialog-btn">Hủy Bỏ</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Land Purchase Dialog -->
            <div id="modal-land-purchase" class="modal hide">
                <div class="modal-overlay"></div>
                <div class="modal-content glassmorphism dialog-modal land-purchase-modal">
                    <div class="modal-header">
                        <h2 id="land-purchase-title">Mua ô đất</h2>
                        <button class="modal-close" id="btn-land-buy-close">×</button>
                    </div>
                    <div class="modal-body dialog-body">
                        <p id="land-purchase-message" class="dialog-message">Kiểm tra cấp để mở rộng nông trại.</p>
                        <div class="land-purchase-summary">
                            <span class="land-purchase-icon">🪧</span>
                            <span>Chọn vàng hoặc kim cương để mở khóa ô đất mới.</span>
                        </div>
                        <div class="dialog-buttons land-purchase-buttons">
                            <button id="btn-land-buy-gold" class="rect-btn success dialog-btn land-pay-btn">Mua bằng Vàng</button>
                            <button id="btn-land-buy-gems" class="rect-btn success dialog-btn land-pay-btn gem-pay">Mua bằng KC</button>
                            <button id="btn-land-buy-cancel" class="rect-btn danger dialog-btn">Hủy</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Floating Notification Banner -->
            <div id="notification-toast" class="toast hide">
                <span id="toast-message">Chào mừng quay lại nông trại!</span>
            </div>

            <!-- Design Mode HUD overlays -->
            <div id="design-banner" class="design-hud-overlay hide">
                <span>🛠️ CHẾ ĐỘ THIẾT KẾ: Kéo thả Nhà, Chuồng, Vườn hoặc Cây cối để sắp xếp</span>
            </div>
            <div id="design-controls" class="design-hud-overlay hide">
                <button id="btn-design-save" class="rect-btn success">Lưu Bố Cục</button>
                <button id="btn-design-cancel" class="rect-btn danger">Hủy Bỏ</button>
            </div>
        </div>
    </div>

</body>

</html>
